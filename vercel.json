{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "buildCommand": "npm run build:frontend",
  "outputDirectory": "frontend/dist",
  "routes": [
    {
      "src": "/api",
      "dest": "/api/index"
    },
    {
      "src": "/api/(.*)",
      "dest": "/api/[...path]"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "methods": ["GET", "HEAD"],
      "dest": "/index.html"
    }
  ]
}
